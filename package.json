{
  "name": "anka-web",
  "version": "2.0.0",
  "description": "Anka Web Browser",
  "main": "src/main.js",
  "author": "Wrait Studio",
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder"
  },
  "dependencies": {
    "axios": "^1.16.1",
    "electron-log": "^5.4.3",
    "electron-updater": "^6.1.7",
    "js-yaml": "^4.1.1"
  },
  "devDependencies": {
    "electron": "^30.0.0",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "com.anka.web",
    "productName": "Anka Web",
    "directories": {
      "output": "dist"
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "assets/icons/logo.png",
      "publish": [
        {
          "provider": "github",
          "owner": "wraitstudio-cmd",
          "repo": "Anka-Web"
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": "always",
      "runAfterFinish": true,
      "installerIcon": "assets/icons/logo.ico",
      "uninstallerIcon": "assets/icons/logo.ico"
    }
  }
}
